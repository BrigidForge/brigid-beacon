{
  "name": "beacon-system",
  "version": "1.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "test:all": "npm run typecheck && npm run build && npm test --workspaces --if-present",
    "ci": "npm run test:all",
    "deploy:hosted": "bash scripts/deploy-hosted.sh",
    "server:install-systemd": "bash scripts/install-systemd.sh",
    "test:e2e": "LD_LIBRARY_PATH=$PWD/.local/lib/extract/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH ./node_modules/.bin/playwright test e2e/owner-flow.spec.ts",
    "dev:up": "node scripts/dev-runtime.mjs up",
    "dev:down": "node scripts/dev-runtime.mjs down",
    "dev:status": "node scripts/dev-runtime.mjs status",
    "db:generate": "node scripts/run-prisma-command.mjs generate",
    "db:push": "node scripts/run-prisma-command.mjs db-push",
    "db:migrate": "node scripts/run-prisma-command.mjs migrate-dev",
    "db:push:prod": "node scripts/run-prisma-command.mjs prod-db-push",
    "db:migrate:prod": "node scripts/run-prisma-command.mjs prod-migrate-deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
