# Beacon API
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/beacon_bsc_testnet"
# Intentionally separate from DATABASE_URL for explicit production schema changes only.
# Leave unset for normal local work.
# MIGRATION_DATABASE_URL="postgresql://admin:password@127.0.0.1:5432/beacon"

# Chain / indexing
CHAIN_ID=97
RPC_URL=https://bsc-testnet.nodereal.io/v1/your-key
FACTORY_ADDRESS=0xFc946E68886841B20c33b4449578c4cC35De5165
START_BLOCK=95886539
INDEXER_STATE_ID=default

# Optional indexing controls
POLL_INTERVAL_MS=60000
BLOCK_CHUNK_SIZE=5000
CONFIRMATIONS=0
REORG_LOOKBACK_BLOCKS=20
EXPLORER_BASE_URL=https://testnet.bscscan.com

# API security / runtime hardening
# Same-origin deploys can leave ALLOWED_ORIGINS empty and use relative viewer API paths.
# For split-host deploys, set a comma-separated allowlist such as:
# ALLOWED_ORIGINS=https://beacon.brigidforge.com,https://operator.brigidforge.com
# ALLOWED_ORIGINS=
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
HELMET_ENABLED=true

# Notifications (omit to disable)
# Managed Telegram connect flow
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_LINK_SECRET=
# TELEGRAM_WEBHOOK_SECRET=
# Optional legacy global delivery fallback. Leave disabled unless you intentionally
# want ownerless/global fallback sends when no subscription exists for an event.
# ENABLE_GLOBAL_NOTIFICATION_FALLBACK=false
# TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=
# WEBHOOK_URL=

# Viewer/API topology
# For local split-host dev, point the viewer at the API explicitly.
VITE_API_BASE_URL=http://localhost:3000
# For production same-origin deploys, prefer leaving VITE_API_BASE_URL unset so
# the viewer uses relative /api paths and avoids CORS drift.

# Public app base URL used to build email preview/confirmation/manage links.
# Set this to the viewer/public host, not the API host, when they differ.
# PUBLIC_APP_BASE_URL=https://beacon.brigidforge.com
PUBLIC_EMAIL_LINK_SECRET=choose-a-long-random-secret-for-public-email-links

# Optional: Brevo public email follow delivery
BREVO_API_KEY=
SES_FROM_EMAIL=beacon-notifications@brigidforge.com
PUBLIC_EMAIL_SUBSCRIPTION_RETENTION_DAYS=30

# Explicit production DB write guard flags.
# These are only used with npm run db:push:prod / npm run db:migrate:prod.
# ALLOW_PROD_DB_WRITE=yes
# PROD_DB_TARGET_CONFIRMATION=beacon-production
