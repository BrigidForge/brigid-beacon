    "@prisma/client": "^5.22.0",
    "ethers": "^6.13.0",
    "prisma": "^5.22.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  }
}
