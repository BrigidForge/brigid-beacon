# vault-ui environment variables
#
# Copy to .env.staging or .env.production on the server (not committed to git).
# The deploy script sources apps/vault-ui/.env.${DEPLOY_ENV} before building.
#
# For local development copy to .env.local.

# URL of the Beacon API. Leave unset when the vault UI is served from the same
# origin as the API (nginx proxies /api/ to the backend).
# Required when vault UI and API are on different origins.
VITE_API_BASE_URL=https://beacon.brigidforge.com/api

# WalletConnect project ID — required for iPhone / QR wallet connections.
# Obtain a free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: pin the WalletConnect provider to a specific CDN version.
# VITE_WALLETCONNECT_CDN_URL=https://esm.sh/@walletconnect/ethereum-provider@2.23.8

# Optional: override the default chain ID (97 = BSC testnet).
# VITE_OPERATOR_CHAIN_ID=97

# Optional: override the default RPC URL for on-chain reads.
# VITE_OPERATOR_RPC_URL=https://bsc-testnet.publicnode.com
